  "version": "1.0.0-beta.4",
  "description": "Develop prompts with Vue SFC or Markdown like pro.",
  "author": {
    "name": "RainbowBird",
    "email": "rbxin2003@outlook.com",
    "url": "https://github.com/luoling8192"
  },
  "contributors": [
