  "license": "MIT",
  "homepage": "https://github.com/moeru-ai/velin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moeru-ai/velin.git",
    "directory": "packages/core-vue"
  },
  "bugs": "https://github.com/moeru-ai/velin/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./render-browser": {
      "types": "./dist/render-browser/index.d.mts",
      "import": "./dist/render-browser/index.mjs"
    },
    "./render-repl": {
      "types": "./dist/render-repl/index.d.mts",
      "import": "./dist/render-repl/index.mjs"
    },
    "./render-node": {
      "types": "./dist/render-node/index.d.mts",
      "import": "./dist/render-node/index.mjs"
    },
    "./render-shared": {
      "types": "./dist/render-shared/index.d.mts",
      "import": "./dist/render-shared/index.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.mts",
      "import": "./dist/browser.mjs"
    }
  },
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "tsdown",
    "stub": "tsdown",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "attw": "attw --pack . --profile esm-only --ignore-rules cjs-resolves-to-esm"
  },
  "peerDependencies": {
    "vue": ">= 3.5.40"
  },
  "dependencies": {
    "@moeru/std": "catalog:",
    "@unrteljs/eval": "catalog:",
    "@velin-dev/source-vue": "workspace:^",
    "@velin-dev/utils": "workspace:^",
    "@vue/compiler-sfc": "catalog:",
    "@vue/reactivity": "catalog:",
    "@vue/runtime-core": "catalog:",
    "@vue/server-renderer": "catalog:",
    "@vue/shared": "catalog:",
    "error-stack-parser": "catalog:",
    "hast-util-from-html": "catalog:",
    "path-browserify-esm": "catalog:",
    "std-env": "catalog:"
  },
  "devDependencies": {
    "@types/hast": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "vue": "catalog:"
  }
}
