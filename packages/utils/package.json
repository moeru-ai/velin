{
  "name": "@velin-dev/utils",
  "type": "module",
  "version": "1.0.0-beta.2",
  "description": "Develop prompts with Vue SFC or Markdown like pro.",
  "author": {
    "name": "RainbowBird",
    "email": "rbxin2003@outlook.com",
    "url": "https://github.com/luoling8192"
  },
  "contributors": [
    {
      "name": "Neko Ayaka",
      "email": "neko@ayaka.moe",
      "url": "https://github.com/nekomeowww"
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/moeru-ai/velin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moeru-ai/velin.git",
    "directory": "packages/utils"
  },
  "bugs": "https://github.com/moeru-ai/velin/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./from-md": {
      "types": "./dist/from-md/index.d.mts",
      "import": "./dist/from-md/index.mjs"
    },
    "./transformers/typescript": {
      "types": "./dist/transformers/typescript/index.d.mts",
      "import": "./dist/transformers/typescript/index.mjs"
    },
    "./to-md": {
      "types": "./dist/to-md/index.d.mts",
      "import": "./dist/to-md/index.mjs"
    }
  },
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "tsdown",
    "stub": "tsdown",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "attw": "attw --pack . --profile esm-only --ignore-rules cjs-resolves-to-esm"
  },
  "dependencies": {
    "hast-util-from-html": "catalog:",
    "hast-util-select": "catalog:",
    "hast-util-to-html": "catalog:",
    "markdown-it": "catalog:",
    "rehype-parse": "catalog:",
    "rehype-remark": "catalog:",
    "rehype-remove-comments": "catalog:",
    "remark-stringify": "catalog:",
    "sucrase": "catalog:",
    "unified": "catalog:",
    "unist-util-remove": "catalog:"
  },
  "devDependencies": {
    "@types/hast": "catalog:"
  }
}
